#set term tikz
#set out "twist.tex"
set term post eps color
set out "twist.eps"

set xlabel '$\phi^\prime$'
set ylabel '$I$'

#set dgrid3d 101,101 qnorm 1
set contour base
set cntrparam levels 15

#set view 73,350

set xrange [0:pi]

splot "twist.res" u 2:1:3 with lines 

set out "twist_SM2.eps"

splot "twist_SM2.res" u 2:1:3 with lines 

unset out
unset term
